
public class Baleia implements Aquatico{
	private Sexo sexo;
	private Porte porte;
	
	public Baleia(Sexo sexo) {
		this.sexo = sexo;
		this.porte = Porte.GRANDE;
	}
	
	public Boolean Alimentar(Alimento alimento) {
		return alimento = Alimento.PEIXES;
	}
	
	public void locomover() {
		this.nadar();
	}
	
	
}
