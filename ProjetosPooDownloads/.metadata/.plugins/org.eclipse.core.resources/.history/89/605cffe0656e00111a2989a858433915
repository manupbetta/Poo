package JogoPo;

import java.util.ArrayList;
import java.util.List;

public class Campeonato {
	private List<Lutavel> lista;
	private final String nome;
	
	public Campeonato(String nome) {
		this.lista = new ArrayList<>();
		this.nome = nome;
	}
	
	public String getNome() {
		return this.nome;
	}
	
	public List<Lutavel> getLista(){
		return this.lista;
	}
	
	public void dueloDeLutadores(Lutavel l1, Lutavel l2) {
		int v1 = l1.calcularVidaTotal();
		int v2 = l2.calcularVidaTotal();
		while(v1 > 0 && v2 > 0) {
			//l1 ataca l2
			v2 -= ((Gladiador) l1).golpePoderoso();
			
			if(v2 <= 0) break;
			
			//l2 ataca l1
			v1 -= ((Gladiador) l2).golpePoderoso();
		}
		
		if(v1 > 0) {
			System.out.println("Vencedor: " + l1.getNome());
		} else {
			System.out.println("Vencedor: " + l2.getNome());
		}
	}
}
